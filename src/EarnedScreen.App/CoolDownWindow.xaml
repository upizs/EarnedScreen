<Window x:Class="EarnedScreen.App.CoolDownWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EarnedScreen.App"
        mc:Ignorable="d"
        Title="Cool Down"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Topmost="True" Background="#111418">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="520">
            <TextBlock Text="⏳ Time's up." FontSize="40" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Text="The Anti-Potato Protocol. Get your body moving before you carry on."
                       FontSize="16" Foreground="#AAB2BD" TextWrapping="Wrap" TextAlignment="Center" Margin="0,12,0,28"/>

            <Border x:Name="ChecklistHost" Background="#1B2026" CornerRadius="10" Padding="24">
                <StackPanel x:Name="ChecklistPanel"/>
            </Border>

            <Button x:Name="DoneButton" Content="I'm back in motion" Height="50" FontSize="16"
                    FontWeight="SemiBold" Margin="0,28,0,0" Click="DoneButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
