<Window x:Class="EarnedScreen.App.CoolDownWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EarnedScreen.App"
        mc:Ignorable="d"
        Title="Cool Down"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="Manual" FontFamily="Segoe UI"
        Topmost="True" Background="{StaticResource WindowBackground}">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="560" Margin="40"
                    RenderTransformOrigin="0.5,0.5">
            <StackPanel.RenderTransform>
                <TranslateTransform x:Name="Slide" Y="0"/>
            </StackPanel.RenderTransform>
            <StackPanel.Triggers>
                <EventTrigger RoutedEvent="StackPanel.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                            <DoubleAnimation Storyboard.TargetName="Slide" Storyboard.TargetProperty="Y"
                                             From="18" To="0" Duration="0:0:0.5"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </StackPanel.Triggers>

            <TextBlock Text="Time's up." FontSize="46" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="Get your body moving before you carry on."
                       FontSize="16" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"
                       TextAlignment="Center" Margin="0,10,0,4"/>
            <TextBlock x:Name="QuoteText" Style="{StaticResource QuoteText}" TextAlignment="Center"
                       HorizontalAlignment="Center" Margin="0,6,0,28"/>

            <Border x:Name="ChecklistHost" CornerRadius="16" Padding="28,22"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource SurfaceBorderBrush}" BorderThickness="1">
                <StackPanel x:Name="ChecklistPanel" MinWidth="300"/>
            </Border>

            <Button x:Name="DoneButton" Style="{StaticResource PrimaryButton}"
                    Content="I'm back in motion" Width="320" Margin="0,28,0,0"
                    Click="DoneButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
